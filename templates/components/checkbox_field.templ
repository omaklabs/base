package components

// CheckboxFieldProps configures a CheckboxField (Checkbox + Label + hidden false input).
type CheckboxFieldProps struct {
	Label    string
	Name     string
	Checked  bool
	Disabled bool
	ErrMsg   string
	Attrs    templ.Attributes
}

func checkboxFieldDefaults(props []CheckboxFieldProps) CheckboxFieldProps {
	if len(props) > 0 {
		return props[0]
	}
	return CheckboxFieldProps{}
}

// CheckboxField renders a complete checkbox field: hidden false input + checkbox + inline label + error.
// The hidden input ensures unchecked checkboxes submit "false" in forms.
templ CheckboxField(props ...CheckboxFieldProps) {
	{{ p := checkboxFieldDefaults(props) }}
	<div>
		<div class="flex items-center gap-2">
			<input type="hidden" name={ p.Name } value="false"/>
			@Checkbox(CheckboxProps{
				ID:       p.Name,
				Name:     p.Name,
				Checked:  p.Checked,
				Disabled: p.Disabled,
				Attrs:    p.Attrs,
			})
			<label for={ p.Name } class="text-sm select-none cursor-pointer">
				{ p.Label }
			</label>
		</div>
		if p.ErrMsg != "" {
			<p id={ p.Name + "-error" } class="text-sm text-destructive mt-1">{ p.ErrMsg }</p>
		}
	</div>
}
